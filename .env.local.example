# Renomeie para .env.local e preencha com os dados reais

# WhatsApp: DDD + numero, somente digitos (ex.: 5562999998888)
NEXT_PUBLIC_WHATSAPP_NUMBER=5562000000000

# Rastreamento (deixe vazio enquanto nao tiver)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=

# Google Tag Manager (opcional: sobrescreve o ID padrao GTM-NWG4XZ9K)
NEXT_PUBLIC_GTM_ID=GTM-NWG4XZ9K
